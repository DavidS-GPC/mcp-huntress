# Huntress API credentials
# Generate at: Huntress Console > Admin > API Credentials
HUNTRESS_API_KEY=your_api_key_here
HUNTRESS_API_SECRET=your_api_secret_here

# Base URL — use the default unless Huntress tells you otherwise
HUNTRESS_BASE_URL=https://api.huntress.io/v1

# Set to true to bypass SSL certificate errors (needed on corporate networks with SSL inspection)
HUNTRESS_IGNORE_TLS_ERRORS=true

# Shared key that team members must provide to connect to this MCP server
# Generate a strong random string: openssl rand -hex 32
MCP_AUTH_KEY=change_me_to_a_strong_random_string

PORT=3004
NODE_ENV=production
